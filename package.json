{
  "name": "zapmix",
  "version": "1.0.5",
  "description": "ZapMix - WhatsApp + vMix + NDI",
  "main": "main.js",
  "author": "Anderson Souza",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "node server.js",
    "build": "electron-builder",
    "dist": "electron-builder --win --x64",
    "publish": "electron-builder --publish always"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "electron-updater": "^6.8.3",
    "express": "^4.18.3",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.5",
    "whatsapp-web.js": "^1.25.0"
  },
  "devDependencies": {
    "electron": "^37.10.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.zapmix.app",
    "productName": "ZapMix",
    "forceCodeSigning": false,
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/*",
      "!release/*",
      "!node_modules/.cache/*"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/logotipo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ZapMix"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "andersoncgpb1",
        "repo": "zapmix",
        "releaseType": "release",
        "private": false
      }
    ]
  }
}